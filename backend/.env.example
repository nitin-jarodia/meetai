# Copy to .env and adjust.

# SQLite — works without Docker (file created next to cwd when you run uvicorn from `backend/`)
DATABASE_URL=sqlite+aiosqlite:///./meetai.db
# PostgreSQL — use with `docker compose up -d` from repo root:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meetai

JWT_SECRET_KEY=change-me-use-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Groq (https://console.groq.com) — free tier
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CORS — comma-separated origins (add http://YOUR_LAN_IP:3000 if you open the app by IP)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DEBUG=false

# Whisper needs ffmpeg to decode MP3/M4A/WAV. Leave empty to use the bundled binary (imageio-ffmpeg).
# FFMPEG_PATH=

# Search tuning. SQLite uses the built-in local semantic fallback. PostgreSQL
# is the recommended production path and can be paired with pgvector.
SEARCH_CHUNK_CHARS=600
SEARCH_EMBEDDING_DIMENSIONS=384
SEARCH_PREFER_PGVECTOR=true
# Embedding backend: "auto" (use sentence-transformers if installed, else hash),
# "sentence-transformers", or "hash".
EMBEDDING_BACKEND=auto
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Background worker (Arq). Leave empty to run audio processing in-process.
# ARQ_REDIS_URL=redis://localhost:6379/0

# Reminders (APScheduler). Poll interval in seconds and lead time for "due soon" events.
REMINDER_POLL_INTERVAL_SECONDS=60
REMINDER_LEAD_TIME_MINUTES=60

# Rolling live summary: minimum chars of new transcript text between AI calls.
LIVE_SUMMARY_INTERVAL_SECONDS=45
LIVE_SUMMARY_MIN_NEW_CHARS=400

# Email notifications (optional). When unset, email sends are no-ops and logged.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=meetai@example.com
# SMTP_USE_TLS=true

# Persist uploaded audio so meetings can be replayed. Files live under uploads/audio/<meeting_id>/.
PERSIST_AUDIO=true

# Diarization backend: "none" (all text as Speaker 1) or "pyannote" (requires pyannote.audio + HF token).
DIARIZATION_BACKEND=none
# HUGGINGFACE_TOKEN=
